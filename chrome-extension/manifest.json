{
  "manifest_version": 3,
  "name": "Identity Vault Autofill Copilot",
  "version": "1.0.0",
  "description": "AI-powered identity document autofill for web forms",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Identity Vault"
  },
  "content_scripts": [
    {
      "all_frames": true,
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}